# Railway环境变量模板
# 请根据实际情况填写以下变量值

# Supabase数据库（必须）
COZE_SUPABASE_URL=https://你的项目ID.supabase.co
COZE_SUPABASE_ANON_KEY=eyJ你的完整anon密钥

# LLM API（必须）
COZE_BOT_TOKEN=你的Bot Token
COZE_API_BASE=https://api.coze.cn

# 应用环境（必须）
NODE_ENV=production

# 数据库变量（Railway自动注入，无需配置）
# DATABASE_URL
# PGHOST
# PGPORT
# PGUSER
# PGPASSWORD
# PGDATABASE